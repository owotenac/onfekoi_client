{
  "expo": {
    "name": "Onfekoi",
    "slug": "Onfekoi",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "onfekoiclient",
    "userInterfaceStyle": "automatic",
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "com.e2digitalstudio.onfekoi",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/foreground.png",
        "backgroundImage": "./assets/images/background.png",
        "monochromeImage": "./assets/images/monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.e2digitalstudio.onfekoi",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "meta": {
        "viewport": "width=device-width, initial-scale=1.0"
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://www.ascanet.fr"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#15151d",
          "dark": {
            "backgroundColor": "#15151d"
          }
        }
      ],
      [
        "./node_modules/react-native-google-mobile-ads/plugin/build/index.js",
        {
          "androidAppId": "ca-app-pub-5464098617109994~4738600282",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "869c9d53-9817-40df-a0aa-16491d669d90"
      }
    },
    "owner": "e2-digital-studio",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/869c9d53-9817-40df-a0aa-16491d669d90"
    }
  }
}